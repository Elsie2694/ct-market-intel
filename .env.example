# PropertyData API key — get this from your PropertyData account (trial or paid).
# Server-side only. NEVER commit the real value.
PROPERTYDATA_API_KEY=your_key_here

# Secret that protects the /api/refresh endpoint. Generate any long random string.
# Vercel cron requests send this automatically as a Bearer token once it's set.
CRON_SECRET=generate_a_long_random_string

# Vercel KV connection vars are added automatically by Vercel when you create a KV store
# and link it to the project. For local dev you can paste them here:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
